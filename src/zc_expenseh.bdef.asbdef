projection;
strict ( 2 );
use draft;

define behavior for ZC_ExpenseH alias ExpenseHeader
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Items { create; with draft; }
}

define behavior for ZC_ExpenseI alias ExpenseItem
{
  use update;
  use delete;

  use association _Header { with draft; }
}